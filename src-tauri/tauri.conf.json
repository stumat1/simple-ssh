{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Simple SSH",
  "version": "../package.json",
  "identifier": "com.simplessh.app",
  "build": {
    "frontendDist": "../dist-web",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "Simple SSH",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 400,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#1e1e1e"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
